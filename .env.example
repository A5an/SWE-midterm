# Root Node API + web baseline
PORT=4000
VITE_API_BASE_URL=http://localhost:4000

# Shared JWT settings
# apps/api uses JWT_ACCESS_SECRET for demo login and collaboration/AI session tokens.
# backend/ uses the full access + refresh token set for the FastAPI auth proof.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_ISSUER=swe-midterm-fastapi

# Optional AI provider override
AI_PROVIDER_API_KEY=
AI_PROVIDER_BASE_URL=
