# Root Node API + web baseline
PORT=4000
VITE_API_BASE_URL=http://localhost:4000
VITE_AUTH_API_BASE_URL=http://127.0.0.1:4021

# Shared JWT settings
# apps/api uses JWT_ACCESS_SECRET for seeded sign-in and collaboration/AI session tokens.
# backend/ uses the full access + refresh token set for the FastAPI auth proof.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_ISSUER=swe-midterm-fastapi
FASTAPI_AUTH_BASE_URL=http://127.0.0.1:4021

# Optional AI provider override
# Default keeps the local demo provider active.
# Switch AI_PROVIDER to openai-compatible to use LM Studio on localhost.
AI_PROVIDER=demo
AI_PROVIDER_API_KEY=lm-studio
AI_PROVIDER_BASE_URL=http://127.0.0.1:1234/v1
AI_MODEL=nvidia.nemotron-mini-4b-instruct
